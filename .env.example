# ==================== AI模型API配置 ====================
# 按照顺序调用，当第一个额度用完后自动切换到下一个

# 1. DeepSeek（首选）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# 2. 火山方舟（字节跳动）
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_MODEL=your_volcengine_model_endpoint

# 3. 智谱AI（GLM-4）
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4

# 4. 阿里云百炼（通义千问）
TONGYI_API_KEY=your_tongyi_api_key_here
TONGYI_MODEL=qwen-turbo

# AI模式配置
AI_MODE_ENABLED=true
DEFAULT_AI_PROVIDER=deepseek

# 调用策略：sequential=顺序调用，fallback=失败切换
AI_CALL_STRATEGY=sequential

# ==================== 第三方服务配置 ====================
SENIVERSE_API_KEY=your_seniverse_key_here
GAODE_API_KEY=your_gaode_key_here
