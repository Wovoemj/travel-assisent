# ==================== AI模型API配置 ====================
# 按照顺序调用，当第一个额度用完后自动切换到下一个

# 1. DeepSeek（首选）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# 2. 火山方舟（字节跳动）
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_MODEL=ep-20240101000000-xxxxx

# 3. 智谱AI（GLM-4）
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4

# 4. 阿里云百炼（通义千问）
TONGYI_API_KEY=your_tongyi_api_key_here
TONGYI_MODEL=qwen-turbo

# 5. OpenAI（备用）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# 6. Claude（备用）
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229

# AI模式配置
AI_MODE_ENABLED=true
DEFAULT_AI_PROVIDER=deepseek
AI_CALL_STRATEGY=sequential

# Flask配置
SECRET_KEY=change-me-to-a-random-string
SESSION_COOKIE_SECURE=false
DEBUG_MODE=true

# 微信配置
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# QQ配置
QQ_APP_ID=
QQ_APP_KEY=

# 微博配置
WEIBO_APP_KEY=
WEIBO_APP_SECRET=

# Redis配置
REDIS_URL=redis://localhost:6379/0

# 数据库（默认SQLite）
DATABASE_URL=sqlite:///travel_destinations.db
