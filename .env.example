# ============================================================
# 智能旅游助手 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# --------------------
# Flask 核心配置
# --------------------
SECRET_KEY=change-me-to-a-random-string-in-production
FLASK_ENV=development
FLASK_DEBUG=true

# --------------------
# 数据库
# --------------------
DATABASE_URI=sqlite:///travel_destinations.db

# --------------------
# Session
# --------------------
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# --------------------
# 开发模式
# true=模拟登录  false=真实登录
# --------------------
DEBUG_MODE=true

# --------------------
# 微信登录 (测试号)
# --------------------
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# --------------------
# QQ 登录
# --------------------
QQ_APP_ID=
QQ_APP_KEY=

# --------------------
# 微博登录
# --------------------
WEIBO_APP_KEY=
WEIBO_APP_SECRET=

# --------------------
# Redis (可选, 用于缓存/状态)
# --------------------
REDIS_URL=redis://localhost:6379/0

# --------------------
# AI 模型配置
# 按优先级排列, 填入对应的 Key 即可启用
# --------------------

# 1. DeepSeek (首选)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 2. 火山方舟 (字节跳动)
VOLCENGINE_API_KEY=
VOLCENGINE_MODEL=ep-20240101000000-xxxxx

# 3. 智谱 AI
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4

# 4. 阿里云百炼 (通义千问)
TONGYI_API_KEY=
TONGYI_MODEL=qwen-turbo

# 5. OpenAI (备用)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# 6. Claude (备用)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229

# --------------------
# AI 策略
# --------------------
DEFAULT_AI_PROVIDER=deepseek
AI_MODE_ENABLED=false
AI_CALL_STRATEGY=sequential
